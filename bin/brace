#!/usr/bin/env bash
set -euo pipefail

# Brace CLI launcher — thin shim.
#
# This script contains no command logic. It resolves WHICH framework version a
# command should run against, makes sure that version's toolchain is available
# locally, and execs into its `com.larvalabs.brace.Cli`. All real work (compile,
# run, dev, test, ops, ...) lives in the framework jar, so the command behaviour
# matches the project's pinned version — not whatever version this launcher
# happens to ship with.
#
#   brace new|version|help   → run against the launcher's bundled toolchain
#   brace <anything-else>    → run against the version pinned in ./pom.xml
#                              (downloaded + cached on first use)
#
# Env overrides:
#   BRACE_HOME          toolchain dir to use as "bundled" (default: derived from
#                       this script's location)
#   BRACE_CACHE         where downloaded toolchains are cached
#                       (default: ~/.brace/cache)
#   BRACE_RELEASE_BASE  base URL for release downloads

# Bumped only when the launcher<->toolchain bootstrap contract changes (how the
# pinned version is read, how toolchains are laid out, how Cli is invoked).
SHIM_VERSION="2"

BRACE_CACHE="${BRACE_CACHE:-$HOME/.brace/cache}"
BRACE_RELEASE_BASE="${BRACE_RELEASE_BASE:-https://github.com/larvalabs/brace/releases/download}"

# --- Chrome (all to stderr; stdout is reserved for captured values / the app) ---
info()    { echo "▸ $*" >&2; }
error()   { echo "✗ $*" >&2; }

# --- Resolve BRACE_HOME (the launcher's own bundled toolchain) ---
# Honour an explicit env override (handy for running an installed launcher
# against a local framework build); otherwise derive it from the script path,
# following symlinks.
if [[ -z "${BRACE_HOME:-}" ]]; then
    SCRIPT_PATH="${BASH_SOURCE[0]}"
    while [[ -L "$SCRIPT_PATH" ]]; do
        SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
        SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
        [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
    done
    BRACE_HOME="$(cd -P "$(dirname "$SCRIPT_PATH")/.." && pwd)"
fi

if [[ ! -d "$BRACE_HOME/lib" ]]; then
    error "BRACE_HOME/lib not found at $BRACE_HOME/lib"
    exit 1
fi

# --- Version resolution ---

# The framework version bundled with this launcher (from the brace jar name).
bundled_version() {
    local jar
    jar=$(ls "$BRACE_HOME"/lib/brace-*.jar 2>/dev/null | grep -v -- '-sources' | head -1)
    [[ -z "$jar" ]] && return 1
    jar="${jar##*/}"; jar="${jar#brace-}"; jar="${jar%.jar}"
    echo "$jar"
}

# The framework version pinned by the current project's pom.xml, if any.
# Tolerant of whitespace/line layout and an optional leading "v" (JitPack tag form).
pinned_version() {
    [[ -f pom.xml ]] || return 1
    local raw
    raw=$(tr -d '[:space:]' < pom.xml \
        | sed -n 's/.*<brace\.version>\(.*\)<\/brace\.version>.*/\1/p')
    raw="${raw#v}"
    [[ -n "$raw" ]] || return 1
    echo "$raw"
}

# Download + unpack the dist zip for a released version into the cache.
fetch_toolchain() {
    local v="$1" dest="$BRACE_CACHE/$v"
    local url="$BRACE_RELEASE_BASE/v$v/brace-$v.zip"
    command -v curl  >/dev/null || { error "curl is required to download brace $v";  return 1; }
    command -v unzip >/dev/null || { error "unzip is required to install brace $v"; return 1; }
    info "Fetching brace $v ..."
    local tmp; tmp="$(mktemp -d)"
    if ! curl -fsSL "$url" -o "$tmp/brace.zip"; then
        rm -rf "$tmp"; error "Could not download brace $v from $url"; return 1
    fi
    if ! unzip -q "$tmp/brace.zip" -d "$tmp"; then
        rm -rf "$tmp"; error "Could not unpack brace $v"; return 1
    fi
    mkdir -p "$BRACE_CACHE"
    rm -rf "$dest"
    # The dist zip unpacks to a top-level brace-<v>/ directory.
    mv "$tmp/brace-$v" "$dest"
    rm -rf "$tmp"
    info "Installed brace $v"
}

# Echo (only) the toolchain home dir for a version, fetching it if needed.
resolve_toolchain() {
    local v="$1"
    if [[ "$v" == "$(bundled_version || true)" ]]; then echo "$BRACE_HOME"; return 0; fi
    if [[ -d "$BRACE_CACHE/$v/lib" ]]; then echo "$BRACE_CACHE/$v"; return 0; fi
    if [[ "$v" == *-SNAPSHOT ]]; then
        error "Project pins brace $v, but SNAPSHOT builds are not published."
        error "Install a matching brace build (or set BRACE_HOME to one), or pin a released version."
        return 1
    fi
    fetch_toolchain "$v" || return 1
    echo "$BRACE_CACHE/$v"
}

# --- Dispatch ---
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    # No project required → run against the launcher's bundled toolchain.
    new|version|--version|-v|help|-h|--help)
        HOME_DIR="$BRACE_HOME"
        ;;
    # Everything else operates on a project → use its pinned version when present,
    # else fall back to bundled so Cli can emit its own "run inside a project" error.
    *)
        if PINNED="$(pinned_version)"; then
            HOME_DIR="$(resolve_toolchain "$PINNED")" || exit 1
        else
            HOME_DIR="$BRACE_HOME"
        fi
        ;;
esac

# exec (not a child) so Ctrl-C / SIGTERM reach Cli directly and its shutdown
# hooks (which stop the app JVM in `run`/`dev`) actually fire.
exec java \
    -Dbrace.home="$HOME_DIR" \
    -Dbrace.launcher="$SHIM_VERSION" \
    -cp "$HOME_DIR/lib/*" \
    com.larvalabs.brace.Cli "$COMMAND" "$@"
